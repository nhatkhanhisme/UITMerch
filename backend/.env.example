# Server
SERVER_PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://your-host:6543/postgres?sslmode=require&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=your-username
SPRING_DATASOURCE_PASSWORD=your-password

# Mail
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true

# Supabase Storage
SUPABASE_STORAGE_ENDPOINT=https://your-project.supabase.com/storage/v1/s3
SUPABASE_PROJECT_URL=https://your-project.supabase.com
SUPABASE_STORAGE_REGION=your-region
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=your-access-key
SUPABASE_STORAGE_S3_SECRET_KEY=your-secret-key

# JWT
APP_JWT_SECRET=your-jwt-secret

# CORS — comma-separated list of allowed origins (no trailing slash, no spaces)
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Swagger UI — set to true only on staging; keep false (default) in production
SWAGGER_ENABLED=false