<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ── Dev / Docker: human-readable console output ───────────────────── -->
  <springProfile name="dev,docker">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE" />
    </root>

    <logger name="com.uitmerch" level="DEBUG" />
  </springProfile>

  <!-- ── Production: structured JSON for log aggregation (ELK, Loki, etc.) -->
  <springProfile name="!dev &amp; !docker">
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"app":"uitmerch-backend"}</customFields>
        <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="JSON_CONSOLE" />
    </root>
  </springProfile>

</configuration>
