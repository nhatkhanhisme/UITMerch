# Keep mock mode on by default so the demo works without a backend.
VITE_USE_MOCK=true

# Real API mode:
# Start the Spring Boot dev profile on 8081 when 8080 is occupied by IIS:
#   cd backend
#   $env:SERVER_PORT="8081"; mvn.cmd spring-boot:run "-Dspring-boot.run.profiles=dev"
VITE_API_BASE_URL=http://localhost:8081
